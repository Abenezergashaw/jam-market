generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           String   @default("admin")
  name           String   @default("")
  isActive       Boolean  @default(true) @map("is_active")
  storeId        Int?     @map("store_id")
  store          Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  permissions    String[] @default([])
  assignedOrders   Order[]  @relation("DeliveryPerson")
  verifiedPayments Order[]  @relation("PaymentVerifier")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String
  slug       String    @unique
  imageUrl   String    @map("image_url")
  isTrending Boolean   @default(false) @map("is_trending")
  products   Product[]

  @@map("categories")
}

model Product {
  id                   Int            @id @default(autoincrement())
  name                 String
  description          String         @default("")
  price                Decimal        @db.Decimal(10, 2)
  imageUrl             String         @map("image_url")
  stock                Int            @default(0)
  brand                String?
  unit                 String?
  weight               String?
  countryOfOrigin      String?        @map("country_of_origin")
  storageInstructions  String?        @map("storage_instructions")
  expiryDate           DateTime?      @map("expiry_date")
  costPrice            Decimal?       @db.Decimal(10, 2) @map("cost_price")
  lowStockThreshold    Int            @default(10) @map("low_stock_threshold")
  isFeatured           Boolean        @default(false) @map("is_featured")
  categoryId           Int?           @map("category_id")
  category             Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems           OrderItem[]
  images               ProductImage[]
  reviews              ProductReview[]
  conversations        Conversation[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Customer {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique @map("telegram_id")
  firstName  String   @map("first_name")
  lastName   String?  @map("last_name")
  username   String?
  phone      String?
  photoUrl   String?  @map("photo_url")
  createdAt  DateTime @default(now()) @map("created_at")
  orders     Order[]
  reviews    ProductReview[]
  conversations Conversation[]

  @@map("customers")
}

model Order {
  id            Int           @id @default(autoincrement())
  customerName  String        @map("customer_name")
  phone         String
  address       String
  notes         String?
  status        OrderStatus   @default(PENDING)
  paymentMethod        String        @default("COD") @map("payment_method")
  paymentStatus        PaymentStatus @default(PENDING) @map("payment_status")
  receiptImageUrl      String?       @map("receipt_image_url")
  paymentReferenceCode String?       @map("payment_reference_code")
  paymentNote          String?       @map("payment_note")
  paymentVerifiedAt    DateTime?     @map("payment_verified_at")
  paymentVerifiedById  Int?          @map("payment_verified_by_id")
  paymentVerifiedBy    User?         @relation("PaymentVerifier", fields: [paymentVerifiedById], references: [id], onDelete: SetNull)
  totalPrice    Decimal       @db.Decimal(10, 2) @map("total_price")
  deliveryFee   Decimal       @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  createdAt     DateTime      @default(now()) @map("created_at")
  customerId    Int?          @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lat           Decimal?      @db.Decimal(10, 8)
  lng           Decimal?      @db.Decimal(11, 8)
  storeId            Int?          @map("store_id")
  store              Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  deliveryPersonId   Int?          @map("delivery_person_id")
  deliveryPerson     User?         @relation("DeliveryPerson", fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  cancelReason       String?       @map("cancel_reason")
  cancelledAt        DateTime?     @map("cancelled_at")
  refundStatus       String?       @map("refund_status")
  refundAmount       Decimal?      @db.Decimal(10, 2) @map("refund_amount")
  refundNote         String?       @map("refund_note")
  items              OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ProductReview {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  customerId Int      @map("customer_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@map("product_reviews")
}

model HeroSlide {
  id        Int     @id @default(autoincrement())
  title     String
  subtitle  String
  tag       String
  ctaLabel  String  @map("cta_label")
  ctaHref   String  @map("cta_href")
  imageUrl  String  @map("image_url")
  position  Int     @default(0)
  isActive  Boolean @default(true) @map("is_active")

  @@map("hero_slides")
}

model Store {
  id               Int      @id @default(autoincrement())
  name             String
  address          String   @default("")
  lat              Decimal? @db.Decimal(10, 7)
  lng              Decimal? @db.Decimal(10, 7)
  isActive         Boolean  @default(true) @map("is_active")
  costPerKm        Decimal? @db.Decimal(10, 2) @map("cost_per_km")
  serviceChargePct Decimal? @db.Decimal(5, 2)  @map("service_charge_pct")
  createdAt        DateTime @default(now()) @map("created_at")
  orders           Order[]
  users            User[]

  @@map("stores")
}

model StoreSettings {
  id                       Int     @id @default(autoincrement())
  minOrderAmount           Decimal @default(0) @db.Decimal(10, 2) @map("min_order_amount")
  costPerKm                Decimal @default(0) @db.Decimal(10, 2) @map("cost_per_km")
  serviceChargePct         Decimal @default(0) @db.Decimal(5, 2)  @map("service_charge_pct")
  estimatedDeliveryMinutes  Int     @default(45) @map("estimated_delivery_minutes")
  storeIsOpen               Boolean @default(true) @map("store_is_open")
  telebirrAccountNumber     String  @default("") @map("telebirr_account_number")
  telebirrAccountName       String  @default("") @map("telebirr_account_name")
  cbeAccountNumber          String  @default("") @map("cbe_account_number")
  cbeAccountName            String  @default("") @map("cbe_account_name")
  boaAccountNumber          String  @default("") @map("boa_account_number")
  boaAccountName            String  @default("") @map("boa_account_name")

  @@map("store_settings")
}

model DeliveryZone {
  id             Int     @id @default(autoincrement())
  name           String
  centerLat      Decimal @db.Decimal(10, 8) @map("center_lat")
  centerLng      Decimal @db.Decimal(11, 8) @map("center_lng")
  radiusKm       Decimal @default(10) @db.Decimal(6, 2) @map("radius_km")
  minOrderAmount Decimal @default(0) @db.Decimal(10, 2) @map("min_order_amount")
  deliveryFee    Decimal @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  isActive       Boolean @default(true) @map("is_active")

  @@map("delivery_zones")
}

model CustomerAuthToken {
  id         Int      @id @default(autoincrement())
  otp        String   @unique @db.VarChar(6)
  telegramId BigInt?  @map("telegram_id")
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  username   String?
  verified   Boolean  @default(false)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("customer_auth_tokens")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  userEmail String?  @map("user_email")
  userRole  String?  @map("user_role")
  action    String
  entity    String
  entityId  Int?     @map("entity_id")
  meta      Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Conversation {
  id         Int       @id @default(autoincrement())
  customerId Int       @map("customer_id")
  productId  Int?      @map("product_id")
  subject    String?   @db.VarChar(200)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  senderRole     String       @map("sender_role")
  senderId       Int          @map("sender_id")
  body           String       @db.Text
  imageUrl       String?      @map("image_url")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COLLECTED
  FAILED
}
