generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String  @map("password_hash")
  role         String  @default("admin")
  isActive     Boolean @default(true) @map("is_active")

  @@map("users")
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String
  slug       String    @unique
  imageUrl   String    @map("image_url")
  isTrending Boolean   @default(false) @map("is_trending")
  products   Product[]

  @@map("categories")
}

model Product {
  id                   Int            @id @default(autoincrement())
  name                 String
  description          String         @default("")
  price                Decimal        @db.Decimal(10, 2)
  imageUrl             String         @map("image_url")
  stock                Int            @default(0)
  brand                String?
  unit                 String?
  weight               String?
  countryOfOrigin      String?        @map("country_of_origin")
  storageInstructions  String?        @map("storage_instructions")
  expiryDate           DateTime?      @map("expiry_date")
  costPrice            Decimal?       @db.Decimal(10, 2) @map("cost_price")
  lowStockThreshold    Int            @default(10) @map("low_stock_threshold")
  isFeatured           Boolean        @default(false) @map("is_featured")
  categoryId           Int?           @map("category_id")
  category             Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems           OrderItem[]
  images               ProductImage[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Customer {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique @map("telegram_id")
  firstName  String   @map("first_name")
  lastName   String?  @map("last_name")
  username   String?
  phone      String?
  photoUrl   String?  @map("photo_url")
  createdAt  DateTime @default(now()) @map("created_at")
  orders     Order[]

  @@map("customers")
}

model Order {
  id            Int           @id @default(autoincrement())
  customerName  String        @map("customer_name")
  phone         String
  address       String
  notes         String?
  status        OrderStatus   @default(PENDING)
  paymentMethod String        @default("COD") @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  totalPrice    Decimal       @db.Decimal(10, 2) @map("total_price")
  deliveryFee   Decimal       @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  createdAt     DateTime      @default(now()) @map("created_at")
  customerId    Int?          @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lat           Decimal?      @db.Decimal(10, 8)
  lng           Decimal?      @db.Decimal(11, 8)
  storeId       Int?          @map("store_id")
  store         Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model HeroSlide {
  id        Int     @id @default(autoincrement())
  title     String
  subtitle  String
  tag       String
  ctaLabel  String  @map("cta_label")
  ctaHref   String  @map("cta_href")
  imageUrl  String  @map("image_url")
  position  Int     @default(0)
  isActive  Boolean @default(true) @map("is_active")

  @@map("hero_slides")
}

model Store {
  id               Int      @id @default(autoincrement())
  name             String
  address          String   @default("")
  lat              Decimal? @db.Decimal(10, 7)
  lng              Decimal? @db.Decimal(10, 7)
  isActive         Boolean  @default(true) @map("is_active")
  costPerKm        Decimal? @db.Decimal(10, 2) @map("cost_per_km")
  serviceChargePct Decimal? @db.Decimal(5, 2)  @map("service_charge_pct")
  createdAt        DateTime @default(now()) @map("created_at")
  orders           Order[]

  @@map("stores")
}

model StoreSettings {
  id                       Int     @id @default(autoincrement())
  minOrderAmount           Decimal @default(0) @db.Decimal(10, 2) @map("min_order_amount")
  costPerKm                Decimal @default(0) @db.Decimal(10, 2) @map("cost_per_km")
  serviceChargePct         Decimal @default(0) @db.Decimal(5, 2)  @map("service_charge_pct")
  estimatedDeliveryMinutes Int     @default(45) @map("estimated_delivery_minutes")
  storeIsOpen              Boolean @default(true) @map("store_is_open")

  @@map("store_settings")
}

model DeliveryZone {
  id             Int     @id @default(autoincrement())
  name           String
  centerLat      Decimal @db.Decimal(10, 8) @map("center_lat")
  centerLng      Decimal @db.Decimal(11, 8) @map("center_lng")
  radiusKm       Decimal @default(10) @db.Decimal(6, 2) @map("radius_km")
  minOrderAmount Decimal @default(0) @db.Decimal(10, 2) @map("min_order_amount")
  deliveryFee    Decimal @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  isActive       Boolean @default(true) @map("is_active")

  @@map("delivery_zones")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COLLECTED
  FAILED
}
